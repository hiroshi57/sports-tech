# ─────────────────────────────────────────────────────────────
# sports-tech Backend — 環境変数サンプル
# このファイルを .env にコピーして実際の値を入力してください
# .env は .gitignore で除外されています（コミット禁止）
# ─────────────────────────────────────────────────────────────

# アプリ設定
APP_NAME="sports-tech API"
APP_VERSION="0.1.0"
DEBUG=true

# データベース (PostgreSQL + pgvector)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sportstech

# Redis (Celery キュー)
REDIS_URL=redis://localhost:6379/0

# JWT 認証
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# AWS S3 (動画ストレージ)
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=sports-tech-videos-dev

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
